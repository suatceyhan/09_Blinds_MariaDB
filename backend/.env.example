# Kopyalayip .env yapin. Asagidakiler ornek / placeholder; gercek sirlar .env icinde kalmali.

APP_NAME=Blinds API
SECRET_KEY=degistir-uzun-rastgele-bir-string
ALGORITHM=HS256
PASSWORD_PEPPER=
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=43200

DATABASE_URL=postgresql://postgres:SIFRE@localhost:5432/veritabani_adi

# true: SQLAlchemy create_all() ile tabloları otomatik oluşturur (dev).
# false: DB şemasını SQL ile yönetin (DB/blinds-postgresql.sql + DB/NN_*.sql).
AUTO_CREATE_TABLES=true

# PostgreSQL RLS: 03 = template+01+02; blinds şeması için ayrıca 04. false = GUC senkronu kapalı.
TENANT_RLS_ENABLED=true

PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
PASSWORD_RESET_EXPOSE_TOKEN=false

FRONTEND_URL=http://localhost:5173

# İsteğe bağlı: yükleme klasörü (şirket logosu). Boş bırakılırsa backend/data/uploads kullanılır.
# UPLOAD_ROOT=D:/path/to/uploads

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=
FROM_NAME=Blinds

EMAIL_USER=
EMAIL_PASS=

# Ikisi doluysa ilk acilista superadmin + rol seed (bos = seed yok)
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Super Admin

# true  = /register üzerinde "Instant signup" + Employee/Company başvuruları; POST /auth/register açık
# false = Employee/Company başvurusu; anında kayıt kapalı (POST /auth/register 403)
PUBLIC_REGISTRATION_ENABLED=true

# Bootstrap + kayit: bu adda rol (or. user) yoksa acilista olusturulur; atama buradan.
DEFAULT_REGISTERED_ROLE_NAME=user

# Onaylanan şirket başvurusu: sahip kullanıcıya verilen rol (yoksa bootstrap’ta oluşturulur).
DEFAULT_COMPANY_OWNER_ROLE_NAME=admin

# Google Calendar — OAuth (estimate → takvim). Boş bırakılırsa bağlantı ve senkron devre dışı (docs/GOOGLE_CALENDAR_SETUP.md).
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/integrations/google/callback
# Yerel http callback için oauthlib (gerekirse): OAUTHLIB_INSECURE_TRANSPORT=1 — localhost/127.0.0.1 redirect’te kod çoğu durumda otomatik ayarlar.
