# Geliştirme: Vite /api → vite.config proxy → FastAPI
VITE_API_BASE=/api

# FastAPI kökeni (sadece `npm run dev` proxy için). Varsayılan: http://127.0.0.1:8810 (`09_Blinds` ile yan yana: o repo 8000 kullanır; 8001 bazı makinelerde dolu veya rezerve olabilir).
# VITE_DEV_API_ORIGIN=http://127.0.0.1:8810

# Pencere başlığı ve marka metinleri (src/lib/brand.ts)
# VITE_APP_TITLE=Benim Uygulamam

# Oturum: bu kadar dakika etkileşim yoksa çıkış (varsayılan 30). 0 = kapat.
# VITE_IDLE_LOGOUT_MINUTES=30
