# Kök örnek ortam dosyası — kopyalayıp .env yapın; commit etmeyin.
# Gerçek değerler backend/ve frontend/.env.example ile ayrıntılandırılabilir.

# Örnek (backend):
# DATABASE_URL=postgresql://user:pass@localhost:5432/suatblinds
# JWT_SECRET=min-32-char-random-secret

# Örnek (frontend / Vite):
# VITE_API_BASE_URL=https://api.suatblinds.com
